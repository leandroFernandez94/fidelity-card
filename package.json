{
  "name": "fidelity-card",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"cd frontend && bun run dev\" \"cd backend && bun run dev\"",
    "build": "cd frontend && bun run build",
    "lint": "eslint .",
    "preview": "cd frontend && bun run preview",
    "api:dev": "cd backend && bun run dev",
    "api:start": "cd backend && bun run start",
    "db:generate": "cd backend && bun run db:generate",
    "db:migrate": "cd backend && bun run db:migrate",
    "db:smoke": "cd backend && bun run db:smoke",
    "seed:admin": "cd backend && bun run seed:admin",
    "seed:servicios": "cd backend && bun run seed:servicios",
    "seed:clientas": "cd backend && bun run seed:clientas",
    "seed:premios": "cd backend && bun run seed:premios",
    "seed:all": "cd backend && bun run seed:all",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.1.0",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^9.0.0"
  }
}

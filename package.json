{
  "name": "fidelity-card",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"bun --cwd frontend run dev\" \"bun --cwd backend run dev\"",
    "build": "bun --cwd frontend run build",
    "lint": "eslint .",
    "preview": "bun --cwd frontend run preview",
    "api:dev": "bun --cwd backend run dev",
    "api:start": "bun --cwd backend run start",
    "db:generate": "bun --cwd backend run db:generate",
    "db:migrate": "bun --cwd backend run db:migrate",
    "db:smoke": "bun --cwd backend run db:smoke",
    "seed:admin": "bun --cwd backend run seed:admin",
    "seed:servicios": "bun --cwd backend run seed:servicios",
    "seed:clientas": "bun --cwd backend run seed:clientas",
    "seed:premios": "bun --cwd backend run seed:premios",
    "seed:all": "bun --cwd backend run seed:all"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.1.0",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^9.0.0"
  }
}
